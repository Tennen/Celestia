# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# LAN IP of the machine running Docker/Colima.
# Required for WebRTC ICE to work when running inside a container.
# Find it with: ifconfig | grep "inet " (macOS) or ip addr (Linux)
CELESTIA_WEBRTC_NAT_IP=192.168.1.x

# TCP port for ICE-TCP. Colima does not support UDP port mapping,
# so ICE-TCP is required. Must match the port mapping in docker-compose.yml.
# Set to 0 to disable ICE-TCP and use UDP instead (not recommended with Colima).
CELESTIA_WEBRTC_TCP_PORT=8081
